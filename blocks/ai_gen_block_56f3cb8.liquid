{% doc %}
  @prompt
    FAQ Section
    
    Layout:
    
    2 column layout (Left + Right)
    
    Both columns width customizable (percentage based – e.g., 40% / 60%)
    
    Responsive (Mobile me stacked layout – Left top, Right bottom)
    
    🔹 LEFT COLUMN LAYOUT
    
    Include following elements:
    
    Icon Setting
    
    Icon picker (SVG upload / icon library)
    
    Icon size control (px)
    
    Icon color picker
    
    Heading
    
    Editable heading text
    
    Font size control (desktop + mobile)
    
    Font weight option
    
    Text color picker
    
    Rich Text
    
    Paragraph / description content
    
    Full rich text editor (bold, link, line break)
    
    Text size control
    
    Text color picker
    
    Button
    
    Button text
    
    Button link (URL)
    
    Open in new tab option
    
    Button background color
    
    Button text color
    
    Border radius control
    
    Padding control
    
    Hover color settings
    
    🔹 RIGHT COLUMN LAYOUT (Accordion)
    
    Create multiple accordion items with:
    
    Accordion Heading (question)
    
    Accordion Content (rich text answer)
    
    Accordion Functionality:
    
    Only ONE accordion open at a time
    
    When a new accordion opens → previously opened accordion automatically closes
    
    Smooth slide animation
    
    Optional icon (+ / -) toggle
    
    Default first accordion open option (toggle setting)
    
    🔹 Section Settings
    
    Add global section controls:
    
    Top Padding (Desktop + Mobile)
    
    Bottom Padding (Desktop + Mobile)
    
    Background Color Picker
    
    Background Image (optional)
    
    Full Width toggle:
    
    Full width
    
    Contained (boxed container width option e.g. 1200px)
    
    Column gap control
    
    Vertical alignment setting (top / center / bottom)
    
    🔹 Responsive Behavior
    
    On mobile: columns stack vertically
    
    Adjustable spacing between stacked sections
    
    Font size separate control for mobile
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-faq-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding-top: {{ block.settings.padding_top_desktop }}px;
    padding-bottom: {{ block.settings.padding_bottom_desktop }}px;
    background-color: {{ block.settings.background_color }};
    {% if block.settings.background_image %}
      background-image: url('{{ block.settings.background_image | image_url: width: 2000 }}');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
    {% endif %}
  }

  .ai-faq-container-{{ ai_gen_id }} {
    {% if block.settings.full_width %}
      width: 100%;
      padding-left: 20px;
      padding-right: 20px;
    {% else %}
      max-width: {{ block.settings.container_width }}px;
      margin-left: auto;
      margin-right: auto;
      padding-left: 20px;
      padding-right: 20px;
    {% endif %}
  }

  .ai-faq-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: {{ block.settings.left_column_width }}% {{ 100 | minus: block.settings.left_column_width }}%;
    gap: {{ block.settings.column_gap }}px;
    align-items: {{ block.settings.vertical_alignment }};
  }

  .ai-faq-left-column-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .ai-faq-icon-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
  }

  .ai-faq-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    color: {{ block.settings.icon_color }};
  }

  .ai-faq-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    fill: currentColor;
  }

  .ai-faq-heading-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.heading_font_size_desktop }}px;
    font-weight: {{ block.settings.heading_font_weight }};
    color: {{ block.settings.heading_color }};
    line-height: 1.2;
  }

  .ai-faq-richtext-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_font_size_desktop }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
  }

  .ai-faq-richtext-{{ ai_gen_id }} p {
    margin: 0 0 12px 0;
  }

  .ai-faq-richtext-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-faq-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    transition: all 0.3s ease;
    font-size: 16px;
    font-weight: 500;
    border: none;
    cursor: pointer;
  }

  .ai-faq-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
  }

  .ai-faq-right-column-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-faq-accordion-item-{{ ai_gen_id }} {
    border: 1px solid {{ block.settings.accordion_border_color }};
    border-radius: {{ block.settings.accordion_border_radius }}px;
    overflow: hidden;
    background-color: {{ block.settings.accordion_bg_color }};
  }

  .ai-faq-accordion-header-{{ ai_gen_id }} {
    width: 100%;
    padding: 20px 24px;
    background: none;
    border: none;
    text-align: left;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    transition: background-color 0.3s ease;
  }

  .ai-faq-accordion-header-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.accordion_hover_bg_color }};
  }

  .ai-faq-accordion-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.accordion_title_font_size }}px;
    font-weight: 600;
    color: {{ block.settings.accordion_title_color }};
    margin: 0;
    flex: 1;
  }

  .ai-faq-accordion-icon-{{ ai_gen_id }} {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
    transition: transform 0.3s ease;
    color: {{ block.settings.accordion_icon_color }};
  }

  .ai-faq-accordion-item-{{ ai_gen_id }}.active .ai-faq-accordion-icon-{{ ai_gen_id }} {
    transform: rotate(45deg);
  }

  .ai-faq-accordion-content-{{ ai_gen_id }} {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }

  .ai-faq-accordion-content-inner-{{ ai_gen_id }} {
    padding: 0 24px 20px 24px;
    font-size: {{ block.settings.accordion_content_font_size }}px;
    color: {{ block.settings.accordion_content_color }};
    line-height: 1.6;
  }

  .ai-faq-accordion-content-inner-{{ ai_gen_id }} p {
    margin: 0 0 12px 0;
  }

  .ai-faq-accordion-content-inner-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-faq-section-{{ ai_gen_id }} {
      padding-top: {{ block.settings.padding_top_mobile }}px;
      padding-bottom: {{ block.settings.padding_bottom_mobile }}px;
    }

    .ai-faq-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.mobile_stack_gap }}px;
    }

    .ai-faq-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_font_size_mobile }}px;
    }

    .ai-faq-richtext-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_font_size_mobile }}px;
    }
  }
{% endstyle %}

<faq-section-{{ ai_gen_id }} class="ai-faq-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-faq-container-{{ ai_gen_id }}">
    <div class="ai-faq-grid-{{ ai_gen_id }}">
      <div class="ai-faq-left-column-{{ ai_gen_id }}">
        {% if block.settings.show_icon %}
          <div class="ai-faq-icon-wrapper-{{ ai_gen_id }}">
            <div class="ai-faq-icon-{{ ai_gen_id }}">
              {{ block.settings.icon_svg }}
            </div>
          </div>
        {% endif %}

        {% if block.settings.heading != blank %}
          <h2 class="ai-faq-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}

        {% if block.settings.rich_text != blank %}
          <div class="ai-faq-richtext-{{ ai_gen_id }}">
            {{ block.settings.rich_text }}
          </div>
        {% endif %}

        {% if block.settings.button_text != blank %}
          <div>
            <a
              href="{{ block.settings.button_link }}"
              class="ai-faq-button-{{ ai_gen_id }}"
              {% if block.settings.button_open_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
            >
              {{ block.settings.button_text }}
            </a>
          </div>
        {% endif %}
      </div>

      <div class="ai-faq-right-column-{{ ai_gen_id }}">
        {% for i in (1..6) %}
          {% liquid
            assign question_key = 'accordion_question_' | append: i
            assign answer_key = 'accordion_answer_' | append: i
            assign question = block.settings[question_key]
            assign answer = block.settings[answer_key]
          %}

          {% if question != blank %}
            <div class="ai-faq-accordion-item-{{ ai_gen_id }} {% if block.settings.first_accordion_open and i == 1 %}active{% endif %}" data-accordion-item>
              <button class="ai-faq-accordion-header-{{ ai_gen_id }}" aria-expanded="{% if block.settings.first_accordion_open and i == 1 %}true{% else %}false{% endif %}">
                <h3 class="ai-faq-accordion-title-{{ ai_gen_id }}">{{ question }}</h3>
                <div class="ai-faq-accordion-icon-{{ ai_gen_id }}">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="12" y1="5" x2="12" y2="19"></line>
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                  </svg>
                </div>
              </button>
              <div class="ai-faq-accordion-content-{{ ai_gen_id }}">
                <div class="ai-faq-accordion-content-inner-{{ ai_gen_id }}">
                  {{ answer }}
                </div>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</faq-section-{{ ai_gen_id }}>

<script>
  (function() {
    class FaqSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.accordionItems = this.querySelectorAll('[data-accordion-item]');
        this.setupAccordions();
      }

      setupAccordions() {
        this.accordionItems.forEach((item, index) => {
          const header = item.querySelector('.ai-faq-accordion-header-{{ ai_gen_id }}');
          const content = item.querySelector('.ai-faq-accordion-content-{{ ai_gen_id }}');
          const contentInner = item.querySelector('.ai-faq-accordion-content-inner-{{ ai_gen_id }}');

          if (item.classList.contains('active')) {
            content.style.maxHeight = contentInner.scrollHeight + 'px';
          }

          header.addEventListener('click', () => {
            const isActive = item.classList.contains('active');

            this.accordionItems.forEach((otherItem) => {
              if (otherItem !== item) {
                otherItem.classList.remove('active');
                const otherContent = otherItem.querySelector('.ai-faq-accordion-content-{{ ai_gen_id }}');
                const otherHeader = otherItem.querySelector('.ai-faq-accordion-header-{{ ai_gen_id }}');
                otherContent.style.maxHeight = '0';
                otherHeader.setAttribute('aria-expanded', 'false');
              }
            });

            if (isActive) {
              item.classList.remove('active');
              content.style.maxHeight = '0';
              header.setAttribute('aria-expanded', 'false');
            } else {
              item.classList.add('active');
              content.style.maxHeight = contentInner.scrollHeight + 'px';
              header.setAttribute('aria-expanded', 'true');
            }
          });
        });
      }
    }

    customElements.define('faq-section-{{ ai_gen_id }}', FaqSection{{ ai_gen_id }});
  })();
</script>

