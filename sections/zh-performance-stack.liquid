{% comment %}
  ZH Performance Stack Section
  "PERFORMANCE STACK" — Ingredient comparison + ingredient grid
  FILE: sections/zh-performance-stack.liquid
{% endcomment %}

<section
  class="zh-section zh-perf"
  id="zh-perf-{{ section.id }}"
>
  <div class="zh-container">
    {%- comment %} Section Header {%- endcomment %}
    <div class="zh-perf__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="zh-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="zh-perf__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="zh-perf__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    <div class="zh-perf__body">
      {%- comment %} Left: Comparison table {%- endcomment %}
      <div class="zh-perf__comparison">
        <div class="zh-perf__compare-table">
          {%- comment %} Standard Drink column (negative) {%- endcomment %}
          <div class="zh-perf__compare-col zh-perf__compare-col--bad">
            <div class="zh-perf__compare-header">
              <span class="zh-perf__compare-label zh-perf__compare-label--bad">{{ section.settings.col_bad_label | default: "Standard Issue" }}</span>
            </div>
            <ul class="zh-perf__compare-list">
              {%- for i in (1..5) -%}
                {%- assign item_key = 'bad_item_' | append: i -%}
                {%- if section.settings[item_key] != blank -%}
                  <li class="zh-perf__compare-item zh-perf__compare-item--bad">
                    <span class="zh-perf__compare-icon zh-perf__compare-icon--bad">✕</span>
                    {{ section.settings[item_key] }}
                  </li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          </div>

          {%- comment %} Zero Hour column (positive) {%- endcomment %}
          <div class="zh-perf__compare-col zh-perf__compare-col--good">
            <div class="zh-perf__compare-header">
              <span class="zh-perf__compare-label zh-perf__compare-label--good">{{ section.settings.col_good_label | default: "Zero Hour Drink" }}</span>
              <span class="zh-perf__compare-badge">SUPERIOR</span>
            </div>
            <ul class="zh-perf__compare-list">
              {%- for i in (1..5) -%}
                {%- assign item_key = 'good_item_' | append: i -%}
                {%- if section.settings[item_key] != blank -%}
                  <li class="zh-perf__compare-item zh-perf__compare-item--good">
                    <span class="zh-perf__compare-icon zh-perf__compare-icon--good">✓</span>
                    {{ section.settings[item_key] }}
                  </li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          </div>
        </div>
      </div>

      {%- comment %} Right: Ingredients grid {%- endcomment %}
      <div class="zh-perf__ingredients">
        <div class="zh-perf__ingr-grid">
          {%- for i in (1..9) -%}
            {%- liquid
              assign ingr_name_key = 'ingr_' | append: i | append: '_name'
              assign ingr_desc_key = 'ingr_' | append: i | append: '_desc'
              assign ingr_name = section.settings[ingr_name_key]
              assign ingr_desc = section.settings[ingr_desc_key]
            -%}
            {%- if ingr_name != blank -%}
              <div class="zh-perf__ingr-card">
                <div class="zh-perf__ingr-dot"></div>
                <div class="zh-perf__ingr-content">
                  <span class="zh-perf__ingr-name">{{ ingr_name }}</span>
                  {%- if ingr_desc != blank -%}
                    <span class="zh-perf__ingr-desc">{{ ingr_desc }}</span>
                  {%- endif -%}
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  /* ============================================================
     ZH PERFORMANCE STACK SECTION
     ============================================================ */
  .zh-perf {
    background-color: #0b0b0b;
    padding-block: clamp(60px, 8vw, 100px);
    position: relative;
    overflow: hidden;
  }

  .zh-perf::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 20% 50%, rgba(47, 58, 47, 0.08) 0%, transparent 60%),
      radial-gradient(circle at 80% 30%, rgba(255, 255, 255, 0.02) 0%, transparent 50%);
    pointer-events: none;
  }

  .zh-perf__header {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    margin-bottom: clamp(40px, 5vw, 64px);
    position: relative;
  }

  .zh-perf__heading {
    font-family: 'Anton', sans-serif;
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #ffffff;
    margin: 0;
  }

  .zh-perf__subheading {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.45);
    letter-spacing: 0.04em;
    max-width: 500px;
    line-height: 1.6;
    margin: 0;
    text-align: center;
  }

  /* Body: two columns */
  .zh-perf__body {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(32px, 5vw, 80px);
    align-items: start;
    position: relative;
  }

  /* ---- COMPARISON TABLE ---- */
  .zh-perf__comparison {
    position: sticky;
    top: 80px;
  }

  .zh-perf__compare-table {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 10px;
    overflow: hidden;
  }

  .zh-perf__compare-col {
    padding: 0;
  }

  .zh-perf__compare-col--bad {
    background: rgba(255, 255, 255, 0.02);
  }

  .zh-perf__compare-col--good {
    background: rgba(47, 58, 47, 0.15);
  }

  .zh-perf__compare-header {
    padding: 16px 20px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .zh-perf__compare-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .zh-perf__compare-label--bad {
    color: rgba(255, 255, 255, 0.4);
  }

  .zh-perf__compare-label--good {
    color: #ffffff;
  }

  .zh-perf__compare-badge {
    display: inline-block;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #0b0b0b;
    background: #ffffff;
    padding: 3px 8px;
    border-radius: 100px;
    width: fit-content;
  }

  .zh-perf__compare-list {
    list-style: none;
    margin: 0;
    padding: 16px 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .zh-perf__compare-item {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.875rem;
    display: flex;
    align-items: center;
    gap: 10px;
    line-height: 1.4;
  }

  .zh-perf__compare-item--bad {
    color: rgba(255, 255, 255, 0.35);
    text-decoration: line-through;
    text-decoration-color: rgba(255, 255, 255, 0.15);
  }

  .zh-perf__compare-item--good {
    color: rgba(255, 255, 255, 0.85);
  }

  .zh-perf__compare-icon {
    flex-shrink: 0;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.625rem;
    font-weight: 700;
  }

  .zh-perf__compare-icon--bad {
    background: rgba(255, 60, 60, 0.12);
    color: rgba(255, 60, 60, 0.6);
  }

  .zh-perf__compare-icon--good {
    background: rgba(47, 58, 47, 0.4);
    color: #6db86d;
  }

  /* ---- INGREDIENTS GRID ---- */
  .zh-perf__ingr-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 10px;
    overflow: hidden;
  }

  .zh-perf__ingr-card {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 18px 24px;
    background: rgba(255, 255, 255, 0.02);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    transition: background 0.2s ease;
  }

  .zh-perf__ingr-card:last-child {
    border-bottom: none;
  }

  .zh-perf__ingr-card:hover {
    background: rgba(255, 255, 255, 0.04);
  }

  .zh-perf__ingr-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.3);
    flex-shrink: 0;
    margin-top: 6px;
  }

  .zh-perf__ingr-content {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .zh-perf__ingr-name {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9375rem;
    font-weight: 600;
    color: #ffffff;
    line-height: 1.3;
  }

  .zh-perf__ingr-desc {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.5;
  }

  /* ============================================================
     RESPONSIVE
     ============================================================ */
  @media (max-width: 899px) {
    .zh-perf__body {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .zh-perf__comparison {
      position: static;
    }
  }
{% endstylesheet %}

