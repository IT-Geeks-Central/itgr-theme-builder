      "label": "Overlay opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 60,
      "unit": "%"
    }
  ],
  "presets": [
    {
      "name": "ZH Hero",
      "settings": {
        "eyebrow": "Veteran Owned & Operated",
        "heading": "Fuel When It Matters",
        "subheading": "Performance Energy Built for Operators Under Pressure.",
        "badge_1": "Veteran Owned",
