{% comment %}
  ZH FAQ Section — "FREQUENTLY ASKED QUESTIONS"
  Accordion items with smooth open/close
  FILE: sections/zh-faq.liquid
{% endcomment %}

<section
  class="zh-section zh-faq"
  id="zh-faq-{{ section.id }}"
>
  {%- if section.settings.bg_image != blank or section.settings.fallback_bg_url != blank -%}
    <div class="zh-faq__bg">
      {%- if section.settings.bg_image != blank -%}
        <img
          src="{{ section.settings.bg_image | image_url: width: 1600 }}"
          alt=""
          role="presentation"
          loading="lazy"
          width="1600"
          height="900"
        >
      {%- else -%}
        <img
          src="{{ section.settings.fallback_bg_url }}"
          alt=""
          role="presentation"
          loading="lazy"
          width="1600"
          height="900"
        >
      {%- endif -%}
      <div class="zh-faq__bg-overlay"></div>
    </div>
  {%- endif -%}

  <div class="zh-container zh-faq__inner">
    {%- comment %} Left: Header {%- endcomment %}
    <div class="zh-faq__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="zh-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="zh-faq__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="zh-faq__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
      {%- if section.settings.support_label != blank -%}
        <a
          href="{{ section.settings.support_url | default: '#' }}"
          class="zh-btn zh-btn--outline zh-faq__support-btn"
        >
          {{ section.settings.support_label }}
        </a>
      {%- endif -%}
    </div>

    {%- comment %} Right: Accordion {%- endcomment %}
    <div class="zh-faq__accordion">
      {%- for i in (1..8) -%}
        {%- liquid
          assign q_key = 'faq_' | append: i | append: '_question'
          assign a_key = 'faq_' | append: i | append: '_answer'
          assign q = section.settings[q_key]
          assign a = section.settings[a_key]
        -%}
        {%- if q != blank -%}
          <details class="zh-faq__item" {% if i == 1 %}open{% endif %}>
            <summary class="zh-faq__question">
              <span class="zh-faq__question-text">{{ q }}</span>
              <span class="zh-faq__toggle" aria-hidden="true">
                <svg class="zh-faq__toggle-icon" width="20" height="20" viewBox="0 0 20 20" fill="none">
                  <path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </summary>
            {%- if a != blank -%}
              <div class="zh-faq__answer">
                <div class="zh-faq__answer-inner">
                  {{ a }}
                </div>
              </div>
            {%- endif -%}
          </details>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  /* ============================================================
     ZH FAQ SECTION
     ============================================================ */
  .zh-faq {
    background-color: #0b0b0b;
    padding-block: clamp(60px, 8vw, 100px);
    position: relative;
    overflow: hidden;
  }

  /* Background image */
  .zh-faq__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .zh-faq__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: brightness(0.15) saturate(0.3);
  }

  .zh-faq__bg-overlay {
    position: absolute;
    inset: 0;
    background: rgba(11, 11, 11, 0.75);
  }

  .zh-faq__inner {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: clamp(40px, 6vw, 100px);
    align-items: start;
    position: relative;
    z-index: 1;
  }

  /* Left header */
  .zh-faq__header {
    display: flex;
    flex-direction: column;
    gap: 14px;
    position: sticky;
    top: 80px;
  }

  .zh-faq__heading {
    font-family: 'Anton', sans-serif;
    font-size: clamp(2rem, 3.5vw, 3rem);
    line-height: 1;
    text-transform: uppercase;
    color: #ffffff;
    margin: 0;
  }

  .zh-faq__subheading {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9375rem;
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.6;
    margin: 0;
  }

  .zh-faq__support-btn {
    width: fit-content;
    font-size: 0.8125rem;
    padding: 11px 24px;
  }

  /* Accordion */
  .zh-faq__accordion {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .zh-faq__item {
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .zh-faq__item:first-child {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .zh-faq__question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding-block: 22px;
    cursor: pointer;
    list-style: none;
    transition: color 0.2s ease;
  }

  .zh-faq__question::-webkit-details-marker {
    display: none;
  }

  .zh-faq__question:hover .zh-faq__question-text {
    color: #ffffff;
  }

  .zh-faq__question-text {
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.4;
    transition: color 0.2s ease;
  }

  .zh-faq__toggle {
    flex-shrink: 0;
    color: rgba(255, 255, 255, 0.4);
    transition: transform 0.2s ease;
  }

  .zh-faq__toggle-icon {
    display: block;
  }

  .zh-faq__item[open] .zh-faq__toggle {
    transform: rotate(180deg);
    color: rgba(255, 255, 255, 0.7);
  }

  .zh-faq__item[open] .zh-faq__question-text {
    color: #ffffff;
  }

  .zh-faq__answer {
    overflow: hidden;
  }

  .zh-faq__answer-inner {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9375rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.55);
    padding-bottom: 22px;
  }

  .zh-faq__answer-inner p {
    margin: 0;
  }

  /* ============================================================
     RESPONSIVE
     ============================================================ */
  @media (max-width: 899px) {
    .zh-faq__inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .zh-faq__header {
      position: static;
    }
  }
{% endstylesheet %}

