{% comment %}
  ZH Mission Brief Section
  "BUILT FOR THE DISCIPLINED." — Image left, content right with stat badges
  FILE: sections/zh-mission-brief.liquid
{% endcomment %}

<section
  class="zh-section zh-mission"
  id="zh-mission-{{ section.id }}"
>
  <div class="zh-container zh-mission__inner">
    {%- comment %} Left: Product image {%- endcomment %}
    <div class="zh-mission__media">
      {%- if section.settings.image != blank -%}
        <img
          src="{{ section.settings.image | image_url: width: 700 }}"
          alt="{{ section.settings.image.alt | default: section.settings.heading }}"
          loading="lazy"
          width="700"
          height="933"
          class="zh-mission__img"
        >
      {%- else -%}
        <img
          src="{{ section.settings.fallback_image_url }}"
          alt="{{ section.settings.heading }}"
          loading="lazy"
          width="700"
          height="933"
          class="zh-mission__img"
        >
      {%- endif -%}
    </div>

    {%- comment %} Right: Content {%- endcomment %}
    <div class="zh-mission__content">
      {%- if section.settings.eyebrow != blank -%}
        <p class="zh-eyebrow zh-mission__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="zh-mission__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.body_text != blank -%}
        <div class="zh-mission__body">
          {{ section.settings.body_text }}
        </div>
      {%- endif -%}

      {%- comment %} Stat badges row {%- endcomment %}
      <div class="zh-mission__stats">
        {%- if section.settings.stat_1_label != blank -%}
          <div class="zh-mission__stat">
            <span class="zh-mission__stat-value">{{ section.settings.stat_1_value }}</span>
            <span class="zh-mission__stat-label">{{ section.settings.stat_1_label }}</span>
          </div>
        {%- endif -%}
        {%- if section.settings.stat_2_label != blank -%}
          <div class="zh-mission__stat">
            <span class="zh-mission__stat-value">{{ section.settings.stat_2_value }}</span>
            <span class="zh-mission__stat-label">{{ section.settings.stat_2_label }}</span>
          </div>
        {%- endif -%}
        {%- if section.settings.stat_3_label != blank -%}
          <div class="zh-mission__stat">
            <span class="zh-mission__stat-value">{{ section.settings.stat_3_value }}</span>
            <span class="zh-mission__stat-label">{{ section.settings.stat_3_label }}</span>
          </div>
        {%- endif -%}
        {%- if section.settings.stat_4_label != blank -%}
          <div class="zh-mission__stat">
            <span class="zh-mission__stat-value">{{ section.settings.stat_4_value }}</span>
            <span class="zh-mission__stat-label">{{ section.settings.stat_4_label }}</span>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  /* ============================================================
     ZH MISSION BRIEF SECTION
     ============================================================ */
  .zh-mission {
    background-color: #0f0f0f;
    padding-block: clamp(60px, 8vw, 120px);
    overflow: hidden;
  }

  .zh-mission__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: clamp(40px, 6vw, 100px);
  }

  /* Left image */
  .zh-mission__media {
    position: relative;
  }

  .zh-mission__img {
    width: 100%;
    height: auto;
    max-height: 680px;
    object-fit: cover;
    object-position: center top;
    border-radius: 4px;
    filter: grayscale(30%) contrast(1.05);
  }

  /* Right content */
  .zh-mission__content {
    display: flex;
    flex-direction: column;
    gap: clamp(16px, 2vw, 28px);
  }

  .zh-mission__eyebrow {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.45);
    margin: 0;
  }

  .zh-mission__heading {
    font-family: 'Anton', sans-serif;
    font-size: clamp(2.25rem, 4vw, 4.5rem);
    line-height: 1;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    color: #ffffff;
    margin: 0;
  }

  .zh-mission__body {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.0625rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.6);
    max-width: 480px;
  }

  .zh-mission__body p {
    margin: 0 0 0.5em;
  }

  .zh-mission__body p:last-child {
    margin-bottom: 0;
  }

  /* Stats row */
  .zh-mission__stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 6px;
    overflow: hidden;
    margin-top: 8px;
  }

  .zh-mission__stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    padding: 18px 10px;
    background: rgba(255, 255, 255, 0.04);
    text-align: center;
    border-right: 1px solid rgba(255, 255, 255, 0.08);
    transition: background 0.2s ease;
  }

  .zh-mission__stat:last-child {
    border-right: none;
  }

  .zh-mission__stat:hover {
    background: rgba(255, 255, 255, 0.07);
  }

  .zh-mission__stat-value {
    font-family: 'Anton', sans-serif;
    font-size: clamp(1.25rem, 1.8vw, 1.75rem);
    color: #ffffff;
    line-height: 1;
    letter-spacing: 0.02em;
  }

  .zh-mission__stat-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.45);
  }

  /* ============================================================
     RESPONSIVE
     ============================================================ */
  @media (max-width: 899px) {
    .zh-mission__inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .zh-mission__img {
      max-height: 420px;
    }

    .zh-mission__heading {
      font-size: clamp(2rem, 8vw, 3rem);
    }
  }

  @media (max-width: 599px) {
    .zh-mission__stats {
      grid-template-columns: repeat(2, 1fr);
    }

    .zh-mission__stat:nth-child(2) {
      border-right: none;
    }

    .zh-mission__stat:nth-child(3) {
      border-right: 1px solid rgba(255, 255, 255, 0.08);
    }
  }
{% endstylesheet %}

