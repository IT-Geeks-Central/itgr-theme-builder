{% comment %}
  ZH Mission Brief Section
  "BUILT FOR THE DISCIPLINED." — B&W image left, content + stats right
  FILE: sections/zh-mission-brief.liquid
{% endcomment %}

<section
  class="zh-mission"
  id="zh-mission-{{ section.id }}"
>
  <div class="zh-container zh-mission__inner">

    {%- comment %} LEFT: B&W product / hand image {%- endcomment %}
    <div class="zh-mission__media">
      {%- if section.settings.image != blank -%}
        <img
          src="{{ section.settings.image | image_url: width: 700 }}"
          alt="{{ section.settings.image.alt | default: section.settings.heading }}"
          loading="lazy"
          width="700"
          height="920"
          class="zh-mission__img"
        >
      {%- else -%}
        <img
          src="{{ section.settings.fallback_image_url }}"
          alt="{{ section.settings.heading }}"
          loading="lazy"
          width="700"
          height="920"
          class="zh-mission__img"
        >
      {%- endif -%}
    </div>

    {%- comment %} RIGHT: Content {%- endcomment %}
    <div class="zh-mission__content">
      {%- if section.settings.eyebrow != blank -%}
        <p class="zh-mission__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="zh-mission__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.body_text != blank -%}
        <div class="zh-mission__body">{{ section.settings.body_text }}</div>
      {%- endif -%}

      {%- comment %} 4 stats in a row {%- endcomment %}
      <div class="zh-mission__stats">
        {%- for i in (1..4) -%}
          {%- liquid
            assign val_key = 'stat_' | append: i | append: '_value'
            assign lbl_key = 'stat_' | append: i | append: '_label'
            assign s_val = section.settings[val_key]
            assign s_lbl = section.settings[lbl_key]
          -%}
          {%- if s_lbl != blank -%}
            <div class="zh-mission__stat">
              {%- if s_val != blank -%}
                <span class="zh-mission__stat-val">{{ s_val }}</span>
              {%- endif -%}
              <span class="zh-mission__stat-lbl">{{ s_lbl }}</span>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

  </div>
</section>

{% stylesheet %}
/* ================================================================
   ZH MISSION BRIEF
   ================================================================ */
.zh-mission {
  background-color: #0b0b0b;
  padding-block: clamp(60px, 8vw, 110px);
  overflow: hidden;
  position: relative;
}
.zh-mission::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.07), transparent);
}

.zh-mission__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: center;
  gap: clamp(40px, 7vw, 100px);
  max-width: 1200px;
  margin-inline: auto;
  padding-inline: clamp(20px, 5vw, 60px);
}

/* Image */
.zh-mission__media { position: relative; }
.zh-mission__img {
  width: 100%;
  max-height: 660px;
  object-fit: cover;
  object-position: center top;
  border-radius: 6px;
  filter: grayscale(100%) contrast(1.1) brightness(0.85);
  display: block;
}

/* Content */
.zh-mission__content {
  display: flex;
  flex-direction: column;
  gap: clamp(14px, 2vw, 22px);
}
.zh-mission__eyebrow {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.6875rem;
  font-weight: 600;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.38);
  margin: 0;
}
.zh-mission__heading {
  font-family: 'Anton', sans-serif;
  font-size: clamp(2.25rem, 4vw, 4.25rem);
  line-height: 1;
  letter-spacing: -0.01em;
  text-transform: uppercase;
  color: #ffffff;
  margin: 0;
}
.zh-mission__body {
  font-family: 'DM Sans', sans-serif;
  font-size: 1rem;
  line-height: 1.7;
  color: rgba(255,255,255,0.55);
}
.zh-mission__body p { margin: 0 0 0.5em; }
.zh-mission__body p:last-child { margin-bottom: 0; }

/* Stats row */
.zh-mission__stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  margin-top: 8px;
  border: 1px solid rgba(255,255,255,0.09);
  border-radius: 8px;
  overflow: hidden;
}
.zh-mission__stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4px;
  padding: 18px 8px;
  background: rgba(255,255,255,0.03);
  border-right: 1px solid rgba(255,255,255,0.07);
  text-align: center;
  transition: background 0.2s ease;
}
.zh-mission__stat:last-child { border-right: none; }
.zh-mission__stat:hover { background: rgba(255,255,255,0.06); }
.zh-mission__stat-val {
  font-family: 'Anton', sans-serif;
  font-size: clamp(1.125rem, 1.8vw, 1.625rem);
  color: #ffffff;
  line-height: 1;
  letter-spacing: 0.02em;
}
.zh-mission__stat-lbl {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.625rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.42);
}

/* ============================================================
   RESPONSIVE
   ============================================================ */
@media (max-width: 899px) {
  .zh-mission__inner {
    grid-template-columns: 1fr;
    gap: 36px;
  }
  .zh-mission__img { max-height: 380px; }
}
@media (max-width: 479px) {
  .zh-mission__stats { grid-template-columns: repeat(2, 1fr); }
  .zh-mission__stat:nth-child(2) { border-right: none; }
  .zh-mission__stat:nth-child(3) { border-right: 1px solid rgba(255,255,255,0.07); }
}
{% endstylesheet %}

