{% comment %}
  ZH Ambassador Section — "BUILT FOR LEADERS."
  Dark military bg + ambassador program CTA
  FILE: sections/zh-ambassador.liquid
{% endcomment %}

<section
  class="zh-section zh-ambassador"
  id="zh-ambassador-{{ section.id }}"
>
  {%- comment %} Background image {%- endcomment %}
  <div class="zh-ambassador__bg">
    {%- if section.settings.bg_image != blank -%}
      <img
        src="{{ section.settings.bg_image | image_url: width: 1600 }}"
        alt=""
        role="presentation"
        loading="lazy"
        width="1600"
        height="1000"
      >
    {%- else -%}
      <img
        src="{{ section.settings.fallback_bg_url }}"
        alt=""
        role="presentation"
        loading="lazy"
        width="1600"
        height="1000"
      >
    {%- endif -%}
    <div class="zh-ambassador__bg-overlay"></div>
  </div>

  <div class="zh-container zh-ambassador__inner">
    {%- if section.settings.eyebrow != blank -%}
      <p class="zh-eyebrow zh-ambassador__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h2 class="zh-ambassador__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.body_text != blank -%}
      <div class="zh-ambassador__body">
        {{ section.settings.body_text }}
      </div>
    {%- endif -%}

    {%- if section.settings.cta_label != blank -%}
      <a
        href="{{ section.settings.cta_url | default: '#' }}"
        class="zh-btn zh-btn--primary zh-ambassador__cta"
      >
        {{ section.settings.cta_label }}
      </a>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  /* ============================================================
     ZH AMBASSADOR SECTION
     ============================================================ */
  .zh-ambassador {
    background-color: #0b0b0b;
    position: relative;
    padding-block: clamp(80px, 10vw, 140px);
    overflow: hidden;
    text-align: center;
  }

  /* Background */
  .zh-ambassador__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .zh-ambassador__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    filter: brightness(0.3) saturate(0.5);
  }

  .zh-ambassador__bg-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(11, 11, 11, 0.7) 0%,
      rgba(11, 11, 11, 0.4) 50%,
      rgba(11, 11, 11, 0.7) 100%
    );
  }

  /* Content */
  .zh-ambassador__inner {
    position: relative;
    z-index: 1;
    max-width: 720px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(16px, 2vw, 24px);
  }

  .zh-ambassador__eyebrow {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.45);
    margin: 0;
  }

  .zh-ambassador__heading {
    font-family: 'Anton', sans-serif;
    font-size: clamp(2.5rem, 5vw, 5.5rem);
    line-height: 1;
    text-transform: uppercase;
    color: #ffffff;
    margin: 0;
  }

  .zh-ambassador__body {
    font-family: 'DM Sans', sans-serif;
    font-size: 1.0625rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.6);
    max-width: 560px;
    text-align: center;
  }

  .zh-ambassador__body p {
    margin: 0 0 0.5em;
  }

  .zh-ambassador__body p:last-child {
    margin-bottom: 0;
  }

  .zh-ambassador__cta {
    margin-top: 8px;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "ZH Ambassador",
  "tag": null,
  "class": "shopify-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Team Zero Hour"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Built for Leaders."
    },
    {
      "type": "richtext",
      "id": "body_text",
      "label": "Body text",
      "default": "<p>We are building an elite cadre of ambassadors. If you lead from the front, we want you on the team. Affiliate & ambassador program launching soon.</p>"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Apply to Join"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA link"
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "fallback_bg_url",
      "label": "Fallback BG URL",
      "default": "https://framerusercontent.com/images/hmrID4xOfrKpvSXTq5Ak9OvB2ZI.jpg"
    }
  ],
  "presets": [
    {
      "name": "ZH Ambassador",
      "settings": {
        "eyebrow": "Team Zero Hour",
        "heading": "Built for Leaders.",
        "cta_label": "Apply to Join"
      }
    }
  ]
}
{% endschema %}
