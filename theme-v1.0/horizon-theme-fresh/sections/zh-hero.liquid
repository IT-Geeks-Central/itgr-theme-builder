{% comment %}
  ZH Hero Section
  "FUEL WHEN IT MATTERS" — Left text + right dramatic soldier/operator image
  FILE: sections/zh-hero.liquid
{% endcomment %}

<section
  class="zh-hero"
  id="zh-hero-{{ section.id }}"
  style="--hero-min-height: {{ section.settings.min_height }}px;"
>
  {%- comment %} Full-bleed background {%- endcomment %}
  <div class="zh-hero__bg-wrap">
    {%- if section.settings.background_image != blank -%}
      <img
        src="{{ section.settings.background_image | image_url: width: 1920 }}"
        alt=""
        role="presentation"
        loading="eager"
        fetchpriority="high"
        width="1920"
        height="1080"
        class="zh-hero__bg-img"
      >
    {%- elsif section.settings.fallback_bg_url != blank -%}
      <img
        src="{{ section.settings.fallback_bg_url }}"
        alt=""
        role="presentation"
        loading="eager"
        fetchpriority="high"
        width="1920"
        height="1080"
        class="zh-hero__bg-img"
      >
    {%- endif -%}
    <div class="zh-hero__bg-overlay"></div>
  </div>

  <div class="zh-hero__layout">
    {%- comment %} ===== LEFT: Text content ===== {%- endcomment %}
    <div class="zh-hero__left">
      {%- if section.settings.eyebrow != blank -%}
        <p class="zh-hero__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h1 class="zh-hero__heading">{{ section.settings.heading }}</h1>
      {%- endif -%}

      {%- if section.settings.subheading != blank -%}
        <p class="zh-hero__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}

      {%- if section.settings.badge_1 != blank or section.settings.badge_2 != blank -%}
        <div class="zh-hero__badges">
          {%- if section.settings.badge_1 != blank -%}
            <span class="zh-hero__badge">
              <span class="zh-hero__badge-dot"></span>
              {{ section.settings.badge_1 }}
            </span>
          {%- endif -%}
          {%- if section.settings.badge_2 != blank -%}
            <span class="zh-hero__badge">
              <span class="zh-hero__badge-dot"></span>
              {{ section.settings.badge_2 }}
            </span>
          {%- endif -%}
        </div>
      {%- endif -%}

      <div class="zh-hero__ctas">
        {%- if section.settings.cta_primary_label != blank -%}
          <a href="{{ section.settings.cta_primary_url | default: '#' }}" class="zh-hero__btn zh-hero__btn--primary">
            {{ section.settings.cta_primary_label }}
          </a>
        {%- endif -%}
        {%- if section.settings.cta_secondary_label != blank -%}
          <a href="{{ section.settings.cta_secondary_url | default: '#' }}" class="zh-hero__btn zh-hero__btn--ghost">
            {{ section.settings.cta_secondary_label }}
          </a>
        {%- endif -%}
      </div>
    </div>

    {%- comment %} ===== RIGHT: Product / soldier image ===== {%- endcomment %}
    <div class="zh-hero__right">
      {%- if section.settings.hero_image != blank -%}
        <img
          src="{{ section.settings.hero_image | image_url: width: 1000 }}"
          alt="{{ section.settings.hero_image.alt | default: section.settings.heading }}"
          loading="eager"
          fetchpriority="high"
          width="1000"
          height="1200"
          class="zh-hero__product-img"
        >
      {%- elsif section.settings.fallback_hero_image_url != blank -%}
        <img
          src="{{ section.settings.fallback_hero_image_url }}"
          alt="{{ section.settings.heading }}"
          loading="eager"
          fetchpriority="high"
          width="1000"
          height="1200"
          class="zh-hero__product-img"
        >
      {%- endif -%}
    </div>
  </div>

  <div class="zh-hero__bottom-fade"></div>
</section>

{% stylesheet %}
/* ================================================================
   ZH HERO
   ================================================================ */
.zh-hero {
  position: relative;
  background: #050505;
  min-height: var(--hero-min-height, 90vh);
  overflow: hidden;
}

.zh-hero__bg-wrap {
  position: absolute;
  inset: 0;
  z-index: 0;
}
.zh-hero__bg-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: 65% center;
  filter: brightness(0.38);
}
.zh-hero__bg-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    100deg,
    #050505 0%,
    rgba(5,5,5,0.95) 28%,
    rgba(5,5,5,0.55) 58%,
    rgba(5,5,5,0.08) 100%
  );
}
.zh-hero__bottom-fade {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 180px;
  background: linear-gradient(to bottom, transparent, #050505);
  z-index: 2;
  pointer-events: none;
}

.zh-hero__layout {
  position: relative;
  z-index: 3;
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: center;
  min-height: var(--hero-min-height, 90vh);
  max-width: 1280px;
  width: 100%;
  margin-inline: auto;
  padding-inline: clamp(24px, 5vw, 72px);
}

.zh-hero__left {
  display: flex;
  flex-direction: column;
  gap: 18px;
  padding-block: clamp(80px, 10vw, 140px);
  max-width: 560px;
}

.zh-hero__eyebrow {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.6875rem;
  font-weight: 600;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.4);
  margin: 0;
}
.zh-hero__heading {
  font-family: 'Anton', sans-serif;
  font-size: clamp(3.25rem, 6.5vw, 7.5rem);
  line-height: 0.93;
  letter-spacing: -0.01em;
  text-transform: uppercase;
  color: #ffffff;
  margin: 0;
  word-break: break-word;
}
.zh-hero__subheading {
  font-family: 'DM Sans', sans-serif;
  font-size: clamp(0.9375rem, 1.2vw, 1.125rem);
  line-height: 1.65;
  color: rgba(255,255,255,0.58);
  max-width: 420px;
  margin: 0;
}
.zh-hero__badges {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
}
.zh-hero__badge {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.6875rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.6);
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.12);
  padding: 6px 14px 6px 10px;
  border-radius: 100px;
}
.zh-hero__badge-dot {
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: rgba(255,255,255,0.5);
  flex-shrink: 0;
}
.zh-hero__ctas {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  margin-top: 6px;
}
.zh-hero__btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.8125rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  text-decoration: none;
  padding: 13px 28px;
  border-radius: 4px;
  transition: all 0.2s ease;
  white-space: nowrap;
  cursor: pointer;
}
.zh-hero__btn--primary {
  background: #ffffff;
  color: #0b0b0b;
  border: 1px solid #ffffff;
}
.zh-hero__btn--primary:hover {
  background: #dedede;
  border-color: #dedede;
}
.zh-hero__btn--ghost {
  background: transparent;
  color: #ffffff;
  border: 1px solid rgba(255,255,255,0.45);
}
.zh-hero__btn--ghost:hover {
  background: rgba(255,255,255,0.07);
  border-color: rgba(255,255,255,0.75);
}

.zh-hero__right {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  height: 100%;
  padding-block-start: clamp(40px, 6vw, 80px);
}
.zh-hero__product-img {
  width: 100%;
  max-width: 620px;
  height: auto;
  max-height: calc(var(--hero-min-height, 90vh) - 10px);
  object-fit: contain;
  object-position: bottom center;
  filter: drop-shadow(0 24px 80px rgba(0,0,0,0.65));
}

@media (max-width: 959px) {
  .zh-hero__layout {
    grid-template-columns: 1fr;
    min-height: auto;
  }
  .zh-hero__right {
    order: -1;
    max-height: 360px;
    padding-block-start: clamp(80px, 12vw, 120px);
  }
  .zh-hero__product-img { max-height: 360px; max-width: 300px; }
  .zh-hero__left { padding-block-end: clamp(60px, 8vw, 100px); max-width: 100%; }
}
@media (max-width: 479px) {
  .zh-hero__heading { font-size: clamp(2.75rem, 13vw, 4rem); }
  .zh-hero__ctas { flex-direction: column; }
  .zh-hero__btn { width: 100%; justify-content: center; }
  .zh-hero__right { max-height: 260px; }
  .zh-hero__product-img { max-height: 260px; max-width: 220px; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "ZH Hero",
  "class": "zh-section-hero",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Veteran Owned & Operated"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Fuel When It Matters"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Performance Energy Built for Operators Under Pressure."
    },
    {
      "type": "text",
      "id": "badge_1",
      "label": "Badge 1",
      "default": "Veteran Owned"
    },
    {
      "type": "text",
      "id": "badge_2",
      "label": "Badge 2",
      "default": "Zero Sugar"
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "text",
      "id": "cta_primary_label",
      "label": "Primary CTA label",
      "default": "Pre-Order Now"
    },
    {
      "type": "url",
      "id": "cta_primary_url",
      "label": "Primary CTA link"
    },
    {
      "type": "text",
      "id": "cta_secondary_label",
      "label": "Secondary CTA label",
      "default": "Explore Mission"
    },
    {
      "type": "url",
      "id": "cta_secondary_url",
      "label": "Secondary CTA link"
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "fallback_bg_url",
      "label": "Fallback BG URL",
      "default": "https://framerusercontent.com/images/Fuc0CHp4CGwahWlDjAVMhNGTNKQ.png"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero product / operator image"
    },
    {
      "type": "text",
      "id": "fallback_hero_image_url",
      "label": "Fallback hero image URL",
      "default": "https://framerusercontent.com/images/bzluHiLnC5Sy9mKjWjOYRLR2oAA.png"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "min_height",
      "label": "Min height (px)",
      "min": 400,
      "max": 1100,
      "step": 20,
      "default": 860,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 60,
      "unit": "%"
    }
  ],
  "presets": [
    {
      "name": "ZH Hero",
      "settings": {
        "eyebrow": "Veteran Owned & Operated",
        "heading": "Fuel When It Matters",
        "subheading": "Performance Energy Built for Operators Under Pressure.",
        "badge_1": "Veteran Owned",
        "badge_2": "Zero Sugar",
        "cta_primary_label": "Pre-Order Now",
        "cta_secondary_label": "Explore Mission",
        "min_height": 860
      }
    }
  ]
}
{% endschema %}
