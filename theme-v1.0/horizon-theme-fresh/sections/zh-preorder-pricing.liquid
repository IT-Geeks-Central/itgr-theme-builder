{% comment %}
  ZH Pre-Order Pricing Section — "RESERVE YOUR STASH"
  Image left + 3 pricing tier cards right
  FILE: sections/zh-preorder-pricing.liquid
{% endcomment %}

<section
  class="zh-section zh-pricing"
  id="zh-pricing-{{ section.id }}"
>
  <div class="zh-container zh-pricing__inner">
    {%- comment %} Left: Product Image {%- endcomment %}
    <div class="zh-pricing__media">
      {%- if section.settings.product_image != blank -%}
        <img
          src="{{ section.settings.product_image | image_url: width: 700 }}"
          alt="{{ section.settings.product_image.alt | default: 'Zero Hour Drink' }}"
          loading="lazy"
          width="700"
          height="700"
          class="zh-pricing__img"
        >
      {%- else -%}
        <img
          src="{{ section.settings.fallback_image_url }}"
          alt="Zero Hour Drink"
          loading="lazy"
          width="700"
          height="700"
          class="zh-pricing__img"
        >
      {%- endif -%}
    </div>

    {%- comment %} Right: Pricing Content {%- endcomment %}
    <div class="zh-pricing__content">
      {%- if section.settings.eyebrow != blank -%}
        <p class="zh-eyebrow zh-pricing__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.sub_label != blank -%}
        <p class="zh-pricing__sub-label">{{ section.settings.sub_label }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="zh-pricing__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <p class="zh-pricing__description">{{ section.settings.description }}</p>
      {%- endif -%}

      {%- comment %} Pricing Tiers {%- endcomment %}
      <div class="zh-pricing__tiers">
        {%- for i in (1..3) -%}
          {%- liquid
            assign tier_name_key = 'tier_' | append: i | append: '_name'
            assign tier_sub_key = 'tier_' | append: i | append: '_sub'
            assign tier_price_key = 'tier_' | append: i | append: '_price'
            assign tier_recommended_key = 'tier_' | append: i | append: '_recommended'

            assign tier_name = section.settings[tier_name_key]
            assign tier_sub = section.settings[tier_sub_key]
            assign tier_price = section.settings[tier_price_key]
            assign tier_recommended = section.settings[tier_recommended_key]
          -%}
          {%- if tier_name != blank -%}
            <div class="zh-pricing__tier{% if tier_recommended %} zh-pricing__tier--recommended{% endif %}">
              {%- if tier_recommended -%}
                <span class="zh-pricing__tier-badge">Recommended</span>
              {%- endif -%}
              <div class="zh-pricing__tier-body">
                <div class="zh-pricing__tier-info">
                  <span class="zh-pricing__tier-name">{{ tier_name }}</span>
                  {%- if tier_sub != blank -%}
                    <span class="zh-pricing__tier-sub">{{ tier_sub }}</span>
                  {%- endif -%}
                </div>
                <div class="zh-pricing__tier-price">
                  {%- if tier_price != blank -%}
                    <span class="zh-pricing__tier-price-val">{{ tier_price }}</span>
                  {%- endif -%}
                </div>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- comment %} CTA {%- endcomment %}
      {%- if section.settings.cta_label != blank -%}
        <a
          href="{{ section.settings.cta_url | default: '#' }}"
          class="zh-btn zh-btn--primary zh-pricing__cta"
        >
          {{ section.settings.cta_label }}
        </a>
      {%- endif -%}

      {%- if section.settings.disclaimer != blank -%}
        <p class="zh-pricing__disclaimer">{{ section.settings.disclaimer }}</p>
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
  /* ============================================================
     ZH PRE-ORDER PRICING SECTION
     ============================================================ */
  .zh-pricing {
    background-color: #0d0d0d;
    padding-block: clamp(60px, 8vw, 100px);
    overflow: hidden;
    position: relative;
  }

  .zh-pricing::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse at 70% 50%,
      rgba(255, 255, 255, 0.02) 0%,
      transparent 60%
    );
    pointer-events: none;
  }

  .zh-pricing__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: clamp(40px, 6vw, 100px);
    position: relative;
  }

  /* Left image */
  .zh-pricing__media {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .zh-pricing__img {
    width: 100%;
    max-width: 480px;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 30px 60px rgba(0, 0, 0, 0.5));
    border-radius: 8px;
  }

  /* Right content */
  .zh-pricing__content {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .zh-pricing__eyebrow {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.4);
    margin: 0;
  }

  .zh-pricing__sub-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8125rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.3);
    margin: 0;
  }

  .zh-pricing__heading {
    font-family: 'Anton', sans-serif;
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 1;
    text-transform: uppercase;
    color: #ffffff;
    margin: 0;
  }

  .zh-pricing__description {
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.6;
    margin: 0;
  }

  /* Pricing tiers */
  .zh-pricing__tiers {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-block: 8px;
  }

  .zh-pricing__tier {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    overflow: hidden;
    transition: border-color 0.2s ease;
    position: relative;
    cursor: pointer;
  }

  .zh-pricing__tier:hover {
    border-color: rgba(255, 255, 255, 0.2);
  }

  .zh-pricing__tier--recommended {
    background: rgba(255, 255, 255, 0.07);
    border-color: rgba(255, 255, 255, 0.22);
  }

  .zh-pricing__tier-badge {
    display: block;
    background: #ffffff;
    color: #0b0b0b;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 5px 16px;
    text-align: center;
  }

  .zh-pricing__tier-body {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    gap: 12px;
  }

  .zh-pricing__tier-info {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .zh-pricing__tier-name {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9375rem;
    font-weight: 600;
    color: #ffffff;
    line-height: 1.3;
  }

  .zh-pricing__tier-sub {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.45);
  }

  .zh-pricing__tier-price-val {
    font-family: 'Anton', sans-serif;
    font-size: 1.5rem;
    color: #ffffff;
    letter-spacing: 0.02em;
  }

  /* CTA */
  .zh-pricing__cta {
    width: 100%;
    justify-content: center;
    margin-top: 4px;
  }

  .zh-pricing__disclaimer {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.3);
    text-align: center;
    margin: 0;
    line-height: 1.5;
  }

  /* ============================================================
     RESPONSIVE
     ============================================================ */
  @media (max-width: 899px) {
    .zh-pricing__inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .zh-pricing__media {
      order: -1;
    }

    .zh-pricing__img {
      max-width: 300px;
    }
  }
{% endstylesheet %}

