{% comment %}
  ZH Pre-Order Pricing Section — "RESERVE YOUR STASH"
  Split: Product image LEFT + Horizontal 3-tier pricing table RIGHT
  FILE: sections/zh-preorder-pricing.liquid
{% endcomment %}

<section
  class="zh-pricing"
  id="zh-pricing-{{ section.id }}"
>
  <div class="zh-container zh-pricing__inner">

    {%- comment %} LEFT: Product image {%- endcomment %}
    <div class="zh-pricing__media">
      {%- if section.settings.product_image != blank -%}
        <img
          src="{{ section.settings.product_image | image_url: width: 700 }}"
          alt="{{ section.settings.product_image.alt | default: 'Zero Hour Drink' }}"
          loading="lazy"
          width="700"
          height="700"
          class="zh-pricing__img"
        >
      {%- else -%}
        <img
          src="{{ section.settings.fallback_image_url }}"
          alt="Zero Hour Drink"
          loading="lazy"
          width="700"
          height="700"
          class="zh-pricing__img"
        >
      {%- endif -%}
    </div>

    {%- comment %} RIGHT: Content + horizontal pricing table {%- endcomment %}
    <div class="zh-pricing__content">
      {%- if section.settings.eyebrow != blank -%}
        <p class="zh-pricing__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.sub_label != blank -%}
        <p class="zh-pricing__sub-label">{{ section.settings.sub_label }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="zh-pricing__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <p class="zh-pricing__description">{{ section.settings.description }}</p>
      {%- endif -%}

      {%- comment %} Horizontal pricing table — 3 columns {%- endcomment %}
      <div class="zh-pricing__table">
        {%- for i in (1..3) -%}
          {%- liquid
            assign name_key = 'tier_' | append: i | append: '_name'
            assign sub_key = 'tier_' | append: i | append: '_sub'
            assign price_key = 'tier_' | append: i | append: '_price'
            assign rec_key = 'tier_' | append: i | append: '_recommended'
            assign t_name = section.settings[name_key]
            assign t_sub = section.settings[sub_key]
            assign t_price = section.settings[price_key]
            assign t_rec = section.settings[rec_key]
          -%}
          {%- if t_name != blank -%}
            <div class="zh-pricing__cell{% if t_rec %} zh-pricing__cell--rec{% endif %}">
              {%- if t_rec -%}
                <span class="zh-pricing__rec-badge">Best Value</span>
              {%- endif -%}
              <div class="zh-pricing__cell-body">
                <span class="zh-pricing__cell-name">{{ t_name }}</span>
                {%- if t_sub != blank -%}
                  <span class="zh-pricing__cell-sub">{{ t_sub }}</span>
                {%- endif -%}
                <span class="zh-pricing__cell-price">{{ t_price }}</span>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- comment %} CTA Button {%- endcomment %}
      {%- if section.settings.cta_label != blank -%}
        <a
          href="{{ section.settings.cta_url | default: '#' }}"
          class="zh-pricing__cta"
        >
          {{ section.settings.cta_label }}
        </a>
      {%- endif -%}

      {%- if section.settings.disclaimer != blank -%}
        <p class="zh-pricing__disclaimer">{{ section.settings.disclaimer }}</p>
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
/* ================================================================
   ZH PRE-ORDER PRICING — Horizontal table layout
   ================================================================ */
.zh-pricing {
  background-color: #0b0b0b;
  padding-block: clamp(60px, 8vw, 100px);
  overflow: hidden;
  position: relative;
}

.zh-pricing__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: center;
  gap: clamp(40px, 6vw, 90px);
  max-width: 1200px;
  margin-inline: auto;
  padding-inline: clamp(20px, 5vw, 60px);
}

/* LEFT: Image */
.zh-pricing__media {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}
.zh-pricing__img {
  width: 100%;
  max-width: 460px;
  height: auto;
  object-fit: contain;
  filter: drop-shadow(0 30px 60px rgba(0,0,0,0.6));
}

/* RIGHT: Content */
.zh-pricing__content {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.zh-pricing__eyebrow {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.6875rem;
  font-weight: 600;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.38);
  margin: 0;
}
.zh-pricing__sub-label {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.75rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.28);
  margin: 0;
}
.zh-pricing__heading {
  font-family: 'Anton', sans-serif;
  font-size: clamp(1.75rem, 3.5vw, 3.25rem);
  line-height: 1;
  text-transform: uppercase;
  color: #ffffff;
  margin: 0;
}
.zh-pricing__description {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.9375rem;
  color: rgba(255,255,255,0.5);
  line-height: 1.6;
  margin: 0;
}

/* Horizontal 3-column pricing table */
.zh-pricing__table {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0;
  margin-block: 6px;
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 8px;
  overflow: hidden;
}
.zh-pricing__cell {
  position: relative;
  display: flex;
  flex-direction: column;
  background: rgba(255,255,255,0.03);
  border-right: 1px solid rgba(255,255,255,0.08);
  transition: background 0.2s ease;
  cursor: pointer;
}
.zh-pricing__cell:last-child {
  border-right: none;
}
.zh-pricing__cell:hover {
  background: rgba(255,255,255,0.06);
}
.zh-pricing__cell--rec {
  background: rgba(255,255,255,0.07);
  border-color: rgba(255,255,255,0.18);
}
.zh-pricing__rec-badge {
  display: block;
  background: #ffffff;
  color: #0b0b0b;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.5625rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  text-align: center;
  padding: 5px 8px;
}
.zh-pricing__cell-body {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 5px;
  padding: 18px 12px;
  text-align: center;
  flex: 1;
}
.zh-pricing__cell-name {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.8125rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: #ffffff;
  line-height: 1.2;
}
.zh-pricing__cell-sub {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.6875rem;
  color: rgba(255,255,255,0.4);
  text-transform: uppercase;
  letter-spacing: 0.06em;
}
.zh-pricing__cell-price {
  font-family: 'Anton', sans-serif;
  font-size: 1.375rem;
  color: #ffffff;
  letter-spacing: 0.02em;
  margin-top: 4px;
}

/* CTA */
.zh-pricing__cta {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.8125rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  text-decoration: none;
  padding: 14px 28px;
  border-radius: 4px;
  background: #ffffff;
  color: #0b0b0b;
  border: 1px solid #ffffff;
  transition: background 0.2s ease;
  margin-top: 4px;
  cursor: pointer;
}
.zh-pricing__cta:hover {
  background: #dedede;
  border-color: #dedede;
}
.zh-pricing__disclaimer {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.75rem;
  color: rgba(255,255,255,0.3);
  text-align: center;
  margin: 0;
  line-height: 1.5;
}

/* ============================================================
   RESPONSIVE
   ============================================================ */
@media (max-width: 899px) {
  .zh-pricing__inner {
    grid-template-columns: 1fr;
    gap: 40px;
  }
  .zh-pricing__media { order: -1; }
  .zh-pricing__img { max-width: 280px; }
}
@media (max-width: 479px) {
  .zh-pricing__table {
    grid-template-columns: 1fr;
  }
  .zh-pricing__cell {
    border-right: none;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .zh-pricing__cell:last-child {
    border-bottom: none;
  }
}
{% endstylesheet %}

