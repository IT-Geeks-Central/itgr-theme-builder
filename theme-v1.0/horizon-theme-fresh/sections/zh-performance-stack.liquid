{% comment %}
  ZH Performance Stack Section
  Ingredient pills row + Comparison table (left) + Can image + ingredients (right)
  FILE: sections/zh-performance-stack.liquid
{% endcomment %}

<section
  class="zh-perf"
  id="zh-perf-{{ section.id }}"
>
  <div class="zh-container">

    {%- comment %} ── Section Header ── {%- endcomment %}
    <div class="zh-perf__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="zh-perf__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="zh-perf__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>

    {%- comment %} ── Ingredient pills row ── {%- endcomment %}
    <div class="zh-perf__pills">
      {%- for i in (1..9) -%}
        {%- assign name_key = 'ingr_' | append: i | append: '_name' -%}
        {%- assign ingr_name = section.settings[name_key] -%}
        {%- if ingr_name != blank -%}
          <span class="zh-perf__pill">{{ ingr_name }}</span>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- comment %} ── Two-column body ── {%- endcomment %}
    <div class="zh-perf__body">

      {%- comment %} LEFT: Comparison table {%- endcomment %}
      <div class="zh-perf__compare-wrap">
        <div class="zh-perf__compare-table">
          {%- comment %} Standard Issue column {%- endcomment %}
          <div class="zh-perf__col zh-perf__col--bad">
            <div class="zh-perf__col-head">
              <span class="zh-perf__col-label zh-perf__col-label--bad">{{ section.settings.col_bad_label | default: "Standard Issue" }}</span>
            </div>
            <ul class="zh-perf__col-list">
              {%- for i in (1..5) -%}
                {%- assign key = 'bad_item_' | append: i -%}
                {%- if section.settings[key] != blank -%}
                  <li class="zh-perf__item zh-perf__item--bad">
                    <span class="zh-perf__icon zh-perf__icon--bad">✕</span>
                    {{ section.settings[key] }}
                  </li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          </div>
          {%- comment %} Zero Hour column {%- endcomment %}
          <div class="zh-perf__col zh-perf__col--good">
            <div class="zh-perf__col-head">
              <span class="zh-perf__col-label zh-perf__col-label--good">{{ section.settings.col_good_label | default: "Zero Hour Drink" }}</span>
              <span class="zh-perf__superior">SUPERIOR</span>
            </div>
            <ul class="zh-perf__col-list">
              {%- for i in (1..5) -%}
                {%- assign key = 'good_item_' | append: i -%}
                {%- if section.settings[key] != blank -%}
                  <li class="zh-perf__item zh-perf__item--good">
                    <span class="zh-perf__icon zh-perf__icon--good">✓</span>
                    {{ section.settings[key] }}
                  </li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          </div>
        </div>
      </div>

      {%- comment %} RIGHT: Can image + ingredient list {%- endcomment %}
      <div class="zh-perf__right">
        <div class="zh-perf__can-wrap">
          {%- if section.settings.can_image != blank -%}
            <img
              src="{{ section.settings.can_image | image_url: width: 600 }}"
              alt="Zero Hour Drink performance can"
              loading="lazy"
              width="600"
              height="600"
              class="zh-perf__can-img"
            >
          {%- elsif section.settings.can_fallback_url != blank -%}
            <img
              src="{{ section.settings.can_fallback_url }}"
              alt="Zero Hour Drink performance can"
              loading="lazy"
              width="600"
              height="600"
              class="zh-perf__can-img"
            >
          {%- endif -%}
        </div>
        <div class="zh-perf__ingr-list">
          {%- for i in (1..9) -%}
            {%- liquid
              assign name_key = 'ingr_' | append: i | append: '_name'
              assign desc_key = 'ingr_' | append: i | append: '_desc'
              assign ingr_name = section.settings[name_key]
              assign ingr_desc = section.settings[desc_key]
            -%}
            {%- if ingr_name != blank -%}
              <div class="zh-perf__ingr-row">
                <div class="zh-perf__ingr-dot"></div>
                <div>
                  <p class="zh-perf__ingr-name">{{ ingr_name }}</p>
                  {%- if ingr_desc != blank -%}
                    <p class="zh-perf__ingr-desc">{{ ingr_desc }}</p>
                  {%- endif -%}
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>

    </div>
  </div>
</section>

{% stylesheet %}
/* ================================================================
   ZH PERFORMANCE STACK
   ================================================================ */
.zh-perf {
  background-color: #0b0b0b;
  padding-block: clamp(60px, 8vw, 100px);
  overflow: hidden;
  position: relative;
}
.zh-perf::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse at 20% 60%, rgba(47,58,47,0.07) 0%, transparent 55%);
  pointer-events: none;
}
.zh-perf > .zh-container { position: relative; }

/* Header */
.zh-perf__header {
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  margin-bottom: 32px;
}
.zh-perf__eyebrow {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.6875rem;
  font-weight: 600;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.38);
  margin: 0;
}
.zh-perf__heading {
  font-family: 'Anton', sans-serif;
  font-size: clamp(2rem, 4vw, 3.5rem);
  line-height: 1;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  color: #ffffff;
  margin: 0;
}

/* Ingredient pills */
.zh-perf__pills {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  justify-content: center;
  margin-bottom: clamp(36px, 5vw, 60px);
  padding-inline: clamp(0px, 5vw, 60px);
}
.zh-perf__pill {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.75rem;
  font-weight: 500;
  letter-spacing: 0.06em;
  color: rgba(255,255,255,0.55);
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.1);
  padding: 6px 14px;
  border-radius: 100px;
  white-space: nowrap;
  transition: border-color 0.2s ease, color 0.2s ease;
}
.zh-perf__pill:hover {
  border-color: rgba(255,255,255,0.25);
  color: rgba(255,255,255,0.8);
}

/* Two-column body */
.zh-perf__body {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: clamp(32px, 5vw, 72px);
  align-items: start;
}

/* Comparison table */
.zh-perf__compare-table {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1px;
  background: rgba(255,255,255,0.07);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 10px;
  overflow: hidden;
}
.zh-perf__col--bad { background: rgba(255,255,255,0.02); }
.zh-perf__col--good { background: rgba(47,58,47,0.12); }

.zh-perf__col-head {
  padding: 16px 18px;
  border-bottom: 1px solid rgba(255,255,255,0.06);
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.zh-perf__col-label {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.6875rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}
.zh-perf__col-label--bad { color: rgba(255,255,255,0.35); }
.zh-perf__col-label--good { color: #ffffff; }
.zh-perf__superior {
  display: inline-block;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.5625rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: #0b0b0b;
  background: #ffffff;
  padding: 3px 8px;
  border-radius: 100px;
  width: fit-content;
}
.zh-perf__col-list {
  list-style: none;
  margin: 0;
  padding: 14px 18px;
  display: flex;
  flex-direction: column;
  gap: 11px;
}
.zh-perf__item {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.8125rem;
  display: flex;
  align-items: center;
  gap: 9px;
  line-height: 1.4;
}
.zh-perf__item--bad {
  color: rgba(255,255,255,0.3);
  text-decoration: line-through;
  text-decoration-color: rgba(255,255,255,0.12);
}
.zh-perf__item--good { color: rgba(255,255,255,0.82); }
.zh-perf__icon {
  flex-shrink: 0;
  width: 17px;
  height: 17px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.5625rem;
  font-weight: 700;
}
.zh-perf__icon--bad { background: rgba(255,60,60,0.1); color: rgba(255,80,80,0.6); }
.zh-perf__icon--good { background: rgba(47,58,47,0.4); color: #6db86d; }

/* RIGHT: Can + ingredients */
.zh-perf__right {
  display: flex;
  flex-direction: column;
  gap: 24px;
}
.zh-perf__can-wrap {
  display: flex;
  justify-content: center;
}
.zh-perf__can-img {
  width: 100%;
  max-width: 260px;
  height: auto;
  object-fit: contain;
  filter: drop-shadow(0 16px 40px rgba(0,0,0,0.5));
}
.zh-perf__ingr-list {
  display: flex;
  flex-direction: column;
  gap: 0;
  border: 1px solid rgba(255,255,255,0.07);
  border-radius: 8px;
  overflow: hidden;
}
.zh-perf__ingr-row {
  display: flex;
  align-items: flex-start;
  gap: 14px;
  padding: 14px 18px;
  border-bottom: 1px solid rgba(255,255,255,0.05);
  background: rgba(255,255,255,0.02);
  transition: background 0.2s ease;
}
.zh-perf__ingr-row:last-child { border-bottom: none; }
.zh-perf__ingr-row:hover { background: rgba(255,255,255,0.04); }
.zh-perf__ingr-dot {
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: rgba(255,255,255,0.3);
  flex-shrink: 0;
  margin-top: 6px;
}
.zh-perf__ingr-name {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.875rem;
  font-weight: 600;
  color: #ffffff;
  margin: 0 0 2px;
  line-height: 1.3;
}
.zh-perf__ingr-desc {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.75rem;
  color: rgba(255,255,255,0.45);
  margin: 0;
  line-height: 1.5;
}

/* ============================================================
   RESPONSIVE
   ============================================================ */
@media (max-width: 899px) {
  .zh-perf__body {
    grid-template-columns: 1fr;
    gap: 40px;
  }
  .zh-perf__can-wrap { display: none; }
}
{% endstylesheet %}

