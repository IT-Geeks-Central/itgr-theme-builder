{% comment %}
  ZH Product Flavors Section — "OPERATIONAL LOADOUT"
  4 flavor cards with distinct colored atmospheric backgrounds
  FILE: sections/zh-product-flavors.liquid
{% endcomment %}

<section
  class="zh-flavors"
  id="zh-flavors-{{ section.id }}"
>
  <div class="zh-container">
    {%- comment %} ── Section header ── {%- endcomment %}
    <div class="zh-flavors__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="zh-flavors__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="zh-flavors__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="zh-flavors__sub">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    {%- comment %} ── 4 Flavor Cards ── {%- endcomment %}
    <div class="zh-flavors__grid">
      {%- for i in (1..4) -%}
        {%- liquid
          assign name_key = 'flavor_' | append: i | append: '_name'
          assign desc_key = 'flavor_' | append: i | append: '_desc'
          assign btn_key = 'flavor_' | append: i | append: '_btn'
          assign url_key = 'flavor_' | append: i | append: '_url'
          assign img_key = 'flavor_' | append: i | append: '_image'
          assign fallback_key = 'flavor_' | append: i | append: '_fallback_url'
          assign bg_key = 'flavor_' | append: i | append: '_bg_url'
          assign accent_key = 'flavor_' | append: i | append: '_accent'
          assign rating_key = 'flavor_' | append: i | append: '_rating'

          assign flavor_name = section.settings[name_key]
          assign flavor_desc = section.settings[desc_key]
          assign flavor_btn = section.settings[btn_key]
          assign flavor_url = section.settings[url_key]
          assign flavor_image = section.settings[img_key]
          assign flavor_fallback = section.settings[fallback_key]
          assign flavor_bg = section.settings[bg_key]
          assign flavor_accent = section.settings[accent_key]
          assign flavor_rating = section.settings[rating_key]
        -%}
        {%- if flavor_name != blank -%}
          <article
            class="zh-flavor-card"
            style="--card-accent: {{ flavor_accent }};"
          >
            {%- comment %} Card background image {%- endcomment %}
            {%- if flavor_bg != blank -%}
              <div class="zh-flavor-card__bg-img" style="background-image: url('{{ flavor_bg }}');"></div>
            {%- endif -%}
            <div class="zh-flavor-card__bg-overlay"></div>

            {%- comment %} Can image {%- endcomment %}
            <div class="zh-flavor-card__can-wrap">
              {%- if flavor_image != blank -%}
                <img
                  src="{{ flavor_image | image_url: width: 500 }}"
                  alt="{{ flavor_image.alt | default: flavor_name }}"
                  loading="lazy"
                  width="500"
                  height="700"
                  class="zh-flavor-card__can-img"
                >
              {%- elsif flavor_fallback != blank -%}
                <img
                  src="{{ flavor_fallback }}"
                  alt="{{ flavor_name }}"
                  loading="lazy"
                  width="500"
                  height="700"
                  class="zh-flavor-card__can-img"
                >
              {%- endif -%}
            </div>

            {%- comment %} Card body {%- endcomment %}
            <div class="zh-flavor-card__body">
              {%- if flavor_rating != blank -%}
                <div class="zh-flavor-card__rating">
                  <span class="zh-flavor-card__stars">★★★★★</span>
                  <span class="zh-flavor-card__rating-val">{{ flavor_rating }}</span>
                </div>
              {%- endif -%}
              {%- if flavor_name != blank -%}
                <h3 class="zh-flavor-card__name">{{ flavor_name }}</h3>
              {%- endif -%}
              {%- if flavor_desc != blank -%}
                <p class="zh-flavor-card__desc">{{ flavor_desc }}</p>
              {%- endif -%}
              {%- if flavor_btn != blank -%}
                <a
                  href="{{ flavor_url | default: '#' }}"
                  class="zh-flavor-card__btn"
                >
                  {{ flavor_btn }}
                </a>
              {%- endif -%}
            </div>
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
/* ================================================================
   ZH PRODUCT FLAVORS — Operational Loadout
   ================================================================ */
.zh-flavors {
  background-color: #0b0b0b;
  padding-block: clamp(60px, 8vw, 100px);
}

.zh-flavors__header {
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  margin-bottom: clamp(36px, 5vw, 56px);
}
.zh-flavors__eyebrow {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.6875rem;
  font-weight: 600;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.35);
  margin: 0;
}
.zh-flavors__heading {
  font-family: 'Anton', sans-serif;
  font-size: clamp(2rem, 4vw, 3.5rem);
  line-height: 1;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  color: #ffffff;
  margin: 0;
}
.zh-flavors__sub {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.8125rem;
  color: rgba(255,255,255,0.4);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  margin: 0;
}

/* Grid */
.zh-flavors__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14px;
}

/* Flavor Card */
.zh-flavor-card {
  position: relative;
  background: var(--card-accent, #141414);
  border-radius: 10px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  min-height: 460px;
  transition: transform 0.3s ease;
  cursor: pointer;
}
.zh-flavor-card:hover { transform: translateY(-6px); }

/* Card bg atmospheric image */
.zh-flavor-card__bg-img {
  position: absolute;
  inset: 0;
  background-size: cover;
  background-position: center;
  opacity: 0.35;
  transition: opacity 0.3s ease;
}
.zh-flavor-card:hover .zh-flavor-card__bg-img { opacity: 0.5; }
.zh-flavor-card__bg-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to bottom,
    rgba(0,0,0,0) 0%,
    rgba(0,0,0,0.05) 40%,
    rgba(0,0,0,0.75) 85%,
    rgba(0,0,0,0.9) 100%
  );
}

/* Can image */
.zh-flavor-card__can-wrap {
  position: relative;
  z-index: 1;
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28px 20px 16px;
  min-height: 280px;
}
.zh-flavor-card__can-img {
  width: 100%;
  max-width: 200px;
  height: auto;
  max-height: 280px;
  object-fit: contain;
  filter: drop-shadow(0 12px 32px rgba(0,0,0,0.6));
  transition: transform 0.35s ease;
}
.zh-flavor-card:hover .zh-flavor-card__can-img { transform: scale(1.05) translateY(-4px); }

/* Card body */
.zh-flavor-card__body {
  position: relative;
  z-index: 1;
  padding: 16px 20px 22px;
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.zh-flavor-card__rating {
  display: flex;
  align-items: center;
  gap: 6px;
}
.zh-flavor-card__stars {
  font-size: 0.6875rem;
  color: #f5c842;
  letter-spacing: 1px;
}
.zh-flavor-card__rating-val {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.6875rem;
  font-weight: 600;
  color: rgba(255,255,255,0.5);
}
.zh-flavor-card__name {
  font-family: 'Anton', sans-serif;
  font-size: clamp(1rem, 1.5vw, 1.25rem);
  text-transform: uppercase;
  color: #ffffff;
  margin: 0;
  line-height: 1.1;
  letter-spacing: 0.03em;
}
.zh-flavor-card__desc {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.75rem;
  color: rgba(255,255,255,0.5);
  margin: 0;
  line-height: 1.4;
}
.zh-flavor-card__btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  text-decoration: none;
  padding: 10px 18px;
  border: 1px solid rgba(255,255,255,0.3);
  border-radius: 4px;
  color: #ffffff;
  background: transparent;
  transition: background 0.2s ease, border-color 0.2s ease;
  margin-top: 4px;
  width: 100%;
}
.zh-flavor-card__btn:hover {
  background: rgba(255,255,255,0.08);
  border-color: rgba(255,255,255,0.6);
}

/* ============================================================
   RESPONSIVE
   ============================================================ */
@media (max-width: 1099px) {
  .zh-flavors__grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }
}
@media (max-width: 599px) {
  .zh-flavors__grid {
    grid-template-columns: 1fr;
    max-width: 400px;
    margin-inline: auto;
  }
  .zh-flavor-card { min-height: 360px; }
}
{% endstylesheet %}

