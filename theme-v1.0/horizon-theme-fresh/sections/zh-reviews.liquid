{% comment %}
  ZH Customer Reviews Section
  Centered header + 3 stacked-quote review cards
  FILE: sections/zh-reviews.liquid
{% endcomment %}

<section
  class="zh-reviews"
  id="zh-reviews-{{ section.id }}"
>
  <div class="zh-container">

    {%- comment %} Header {%- endcomment %}
    <div class="zh-reviews__header">
      <div class="zh-reviews__avg">
        <span class="zh-reviews__avg-stars">★★★★★</span>
        <span class="zh-reviews__avg-label">{{ section.settings.avg_rating_label | default: "Average Rating" }}</span>
      </div>
      <div class="zh-reviews__title-row">
        <h2 class="zh-reviews__heading">{{ section.settings.heading | default: "Customer Reviews" }}</h2>
        {%- if section.settings.reviews_link_label != blank -%}
          <a href="{{ section.settings.reviews_link_url | default: '#' }}" class="zh-reviews__all-link">
            {{ section.settings.reviews_link_label }}
            <span aria-hidden="true"> →</span>
          </a>
        {%- endif -%}
      </div>
    </div>

    {%- comment %} 3 Review cards {%- endcomment %}
    <div class="zh-reviews__grid">
      {%- for i in (1..3) -%}
        {%- liquid
          assign stars_key   = 'review_' | append: i | append: '_stars'
          assign text_key    = 'review_' | append: i | append: '_text'
          assign name_key    = 'review_' | append: i | append: '_name'
          assign loc_key     = 'review_' | append: i | append: '_location'
          assign avatar_key  = 'review_' | append: i | append: '_avatar'
          assign fb_key      = 'review_' | append: i | append: '_fallback_avatar'
          assign r_stars  = section.settings[stars_key]
          assign r_text   = section.settings[text_key]
          assign r_name   = section.settings[name_key]
          assign r_loc    = section.settings[loc_key]
          assign r_avatar = section.settings[avatar_key]
          assign r_fb     = section.settings[fb_key]
        -%}
        {%- if r_text != blank -%}
          <article class="zh-review-card">
            <div class="zh-review-card__top">
              <div class="zh-review-card__stars">
                {%- assign sc = r_stars | default: 5 | times: 1 -%}
                {%- for s in (1..sc) -%}★{%- endfor -%}
              </div>
            </div>

            <blockquote class="zh-review-card__quote">"{{ r_text }}"</blockquote>

            <footer class="zh-review-card__footer">
              <div class="zh-review-card__avatar">
                {%- if r_avatar != blank -%}
                  <img src="{{ r_avatar | image_url: width: 80 }}" alt="{{ r_name }}" loading="lazy" width="40" height="40">
                {%- elsif r_fb != blank -%}
                  <img src="{{ r_fb }}" alt="{{ r_name }}" loading="lazy" width="40" height="40">
                {%- else -%}
                  <div class="zh-review-card__avatar-placeholder">{{ r_name | upcase | slice: 0, 1 }}</div>
                {%- endif -%}
              </div>
              <div class="zh-review-card__author">
                {%- if r_name != blank -%}<span class="zh-review-card__name">{{ r_name }}</span>{%- endif -%}
                {%- if r_loc != blank -%}<span class="zh-review-card__loc">{{ r_loc }}</span>{%- endif -%}
              </div>
            </footer>
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</section>

{% stylesheet %}
/* ================================================================
   ZH CUSTOMER REVIEWS
   ================================================================ */
.zh-reviews {
  background-color: #0b0b0b;
  padding-block: clamp(60px, 8vw, 100px);
  position: relative;
}
.zh-reviews::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.07), transparent);
}

/* Header */
.zh-reviews__header {
  text-align: center;
  margin-bottom: clamp(36px, 5vw, 56px);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
}
.zh-reviews__avg {
  display: flex;
  align-items: center;
  gap: 10px;
}
.zh-reviews__avg-stars {
  font-size: 1rem;
  color: #f5c842;
  letter-spacing: 2px;
}
.zh-reviews__avg-label {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.75rem;
  font-weight: 500;
  color: rgba(255,255,255,0.4);
  letter-spacing: 0.08em;
  text-transform: uppercase;
}
.zh-reviews__title-row {
  display: flex;
  align-items: baseline;
  gap: 20px;
  flex-wrap: wrap;
  justify-content: center;
}
.zh-reviews__heading {
  font-family: 'Anton', sans-serif;
  font-size: clamp(1.75rem, 3.5vw, 3rem);
  text-transform: uppercase;
  color: #ffffff;
  margin: 0;
  line-height: 1;
}
.zh-reviews__all-link {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.8125rem;
  font-weight: 500;
  color: rgba(255,255,255,0.45);
  text-decoration: none;
  border-bottom: 1px solid rgba(255,255,255,0.18);
  padding-bottom: 1px;
  transition: color 0.2s ease, border-color 0.2s ease;
  white-space: nowrap;
}
.zh-reviews__all-link:hover {
  color: rgba(255,255,255,0.8);
  border-color: rgba(255,255,255,0.45);
}

/* Grid */
.zh-reviews__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
}

/* Review Card */
.zh-review-card {
  background: rgba(255,255,255,0.03);
  border: 1px solid rgba(255,255,255,0.07);
  border-radius: 10px;
  padding: 28px;
  display: flex;
  flex-direction: column;
  gap: 18px;
  transition: border-color 0.2s ease, background 0.2s ease;
}
.zh-review-card:hover {
  border-color: rgba(255,255,255,0.14);
  background: rgba(255,255,255,0.05);
}
.zh-review-card__stars {
  font-size: 0.8125rem;
  color: #f5c842;
  letter-spacing: 2px;
}
.zh-review-card__quote {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.9375rem;
  font-style: italic;
  color: rgba(255,255,255,0.72);
  line-height: 1.65;
  margin: 0;
  flex: 1;
}
.zh-review-card__footer {
  display: flex;
  align-items: center;
  gap: 12px;
  padding-top: 14px;
  border-top: 1px solid rgba(255,255,255,0.06);
}
.zh-review-card__avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
}
.zh-review-card__avatar img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.zh-review-card__avatar-placeholder {
  width: 100%;
  height: 100%;
  background: rgba(255,255,255,0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'DM Sans', sans-serif;
  font-size: 1rem;
  font-weight: 600;
  color: rgba(255,255,255,0.5);
}
.zh-review-card__author {
  display: flex;
  flex-direction: column;
  gap: 3px;
}
.zh-review-card__name {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.875rem;
  font-weight: 600;
  color: #ffffff;
}
.zh-review-card__loc {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.6875rem;
  color: rgba(255,255,255,0.38);
}

/* ============================================================
   RESPONSIVE
   ============================================================ */
@media (min-width: 600px) and (max-width: 899px) {
  .zh-reviews__grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 599px) {
  .zh-reviews__grid {
    grid-template-columns: 1fr;
    max-width: 520px;
    margin-inline: auto;
  }
}
{% endstylesheet %}

